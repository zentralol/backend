# Zentra Backend environment variables
#
# Usage:
#   1. Copy this file to .env:  cp .env.example .env
#   2. Fill in real values. .env is ignored by git and should not be committed.
#   3. Start the service:      node server.js
#
# The app loads .env automatically at startup through dotenv.

# ---------------------------------------------------------------------------
# Service port
# ---------------------------------------------------------------------------
# HTTP port. Defaults to 3000 when unset.
PORT=3000

# ---------------------------------------------------------------------------
# PostgreSQL database connection
# ---------------------------------------------------------------------------
# PostgreSQL connection string. Required.
# Format: postgresql://<username>:<password>@<host>:<port>/<database>
#
# Local example:
#   DATABASE_URL=postgresql://postgres:password@localhost:5432/zentra
#
# Managed databases such as Supabase, Neon, or Railway usually provide a full
# connection URL and may require SSL. server.js enables ssl: { rejectUnauthorized: false }.
DATABASE_URL=postgresql://user:password@localhost:5432/zentra

# Client-side bound on how long a single query may run before failing.
# Defaults to 30000 when unset or invalid. Prevents hung connections from
# leaving queries (and the crowd prediction job's run lock) pending forever.
DB_QUERY_TIMEOUT_MS=30000

# Bound on how long acquiring a connection from the pool may take.
# Defaults to 10000 when unset or invalid.
DB_CONNECT_TIMEOUT_MS=10000

# ---------------------------------------------------------------------------
# Clerk authentication
# ---------------------------------------------------------------------------
# Required for protected API routes. The backend validates Clerk session tokens
# from the Authorization: Bearer <token> header. Use the publishable key and
# secret key from the same Clerk application.
CLERK_PUBLISHABLE_KEY=
CLERK_SECRET_KEY=

# ---------------------------------------------------------------------------
# ML prediction service
# ---------------------------------------------------------------------------
# Base URL for the FastAPI ML service. When unset, the backend falls back to
# precomputed scores from the database.
#
# Local development example when running the ML service on port 8000:
#   ML_API_BASE_URL=http://localhost:8000
#
# Docker network deployment example when backend and ML are both on zentra:
#   ML_API_BASE_URL=http://zentra-ml:8000
ML_API_BASE_URL=http://localhost:8000

# Timeout for ML service calls in milliseconds. Defaults to 5000 when unset or invalid.
ML_API_TIMEOUT_MS=5000

# ---------------------------------------------------------------------------
# Crowd prediction job (attractions)
# ---------------------------------------------------------------------------
# Periodic in-process job that predicts the crowd level for every attraction
# via the ML service and upserts results into attraction_predictions.
# Must be exactly "true" to start the scheduler at boot. Defaults to off.
CROWD_PREDICTION_JOB_ENABLED=false

# Run cadence in milliseconds. Defaults to 300000 (5 minutes) when unset or invalid.
CROWD_PREDICTION_INTERVAL_MS=300000

# Max in-flight ML calls per run. Defaults to 8 when unset or invalid.
CROWD_PREDICTION_CONCURRENCY=8

# Delete prediction rows older than this (by predicted_for). Default 3600000 (1 hour).
CROWD_PREDICTION_RETENTION_MS=3600000

# ---------------------------------------------------------------------------
# Heatmap prediction job (H3 grid)
# ---------------------------------------------------------------------------
# Periodic in-process job that predicts crowd levels for every Manhattan H3
# grid cell across Now + 8 hourly buckets and upserts into heatmap_predictions.
# Must be exactly "true" to start the scheduler at boot. Defaults to off.
HEATMAP_PREDICTION_JOB_ENABLED=false

# Run cadence in milliseconds. Defaults to 1800000 (30 minutes) when unset or invalid.
HEATMAP_PREDICTION_INTERVAL_MS=1800000

# Max in-flight ML calls per target-time bucket. Defaults to 8 when unset or invalid.
HEATMAP_PREDICTION_CONCURRENCY=8

# Number of H3 cells to refresh per target-time bucket. Defaults to 524.
HEATMAP_GRID_LIMIT=524

# Number of future hourly buckets after "Now" to precompute. Defaults to 8.
HEATMAP_HORIZON_HOURS=8

# Delete rows with target_time older than this many hours. Defaults to 48.
HEATMAP_RETENTION_HOURS=48

# ---------------------------------------------------------------------------
# Zentra AI agent service (internal)
# ---------------------------------------------------------------------------
# Base URL for the FastAPI agent service. When unset, the chat endpoint returns
# 503. The gateway streams the agent's SSE response back to the client.
#
# Local development example:
#   AGENT_API_BASE_URL=http://localhost:8010
# Docker network deployment example:
#   AGENT_API_BASE_URL=http://zentra-agent:8010
AGENT_API_BASE_URL=http://localhost:8010

# Timeout for the initial connection to the agent in milliseconds. Defaults to
# 30000 when unset or invalid. Applies until the SSE stream starts flowing.
AGENT_API_TIMEOUT_MS=30000

# Shared secret for Express->agent service-to-service auth, sent as the
# X-Internal-Service-Token header. MUST match the agent's AGENT_INTERNAL_TOKEN.
# Generate: openssl rand -hex 32
AGENT_INTERNAL_TOKEN=

# ---------------------------------------------------------------------------
# Zentra recommend service (internal)
# ---------------------------------------------------------------------------
# Base URL for the zentra-recommend itinerary/recommendation FastAPI service.
# When unset, POST /itinerary/plan and POST /recommend return 503.
#
# Local development example:
#   RECOMMEND_API_BASE_URL=http://localhost:8001
# Docker network deployment example:
#   RECOMMEND_API_BASE_URL=http://zentra-recommend:8001
RECOMMEND_API_BASE_URL=http://localhost:8001

# Timeout for recommend service calls in milliseconds. Defaults to 60000 when
# unset or invalid. Itinerary planning can take longer than quick lookups.
RECOMMEND_API_TIMEOUT_MS=60000
