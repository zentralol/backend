# Zentra Backend environment variables
#
# Usage:
#   1. Copy this file to .env:  cp .env.example .env
#   2. Fill in real values. .env is ignored by git and should not be committed.
#   3. Start the service:      node server.js
#
# The app loads .env automatically at startup through dotenv.

# ---------------------------------------------------------------------------
# Service port
# ---------------------------------------------------------------------------
# HTTP port. Defaults to 3000 when unset.
PORT=3000

# ---------------------------------------------------------------------------
# PostgreSQL database connection
# ---------------------------------------------------------------------------
# PostgreSQL connection string. Required.
# Format: postgresql://<username>:<password>@<host>:<port>/<database>
#
# Local example:
#   DATABASE_URL=postgresql://postgres:password@localhost:5432/zentra
#
# Managed databases such as Supabase, Neon, or Railway usually provide a full
# connection URL and may require SSL. server.js enables ssl: { rejectUnauthorized: false }.
DATABASE_URL=postgresql://user:password@localhost:5432/zentra

# ---------------------------------------------------------------------------
# Clerk authentication
# ---------------------------------------------------------------------------
# Required for protected API routes. The backend validates Clerk session tokens
# from the Authorization: Bearer <token> header.
CLERK_SECRET_KEY=

# Optional. Comma-separated list of allowed token authorized parties, such as
# http://localhost:3001,https://zentra.lol. Recommended in production.
CLERK_AUTHORIZED_PARTIES=

# Optional. Enables networkless Clerk JWT verification when set to the JWKS
# public key from the Clerk Dashboard.
CLERK_JWT_KEY=

# Optional admin controls for /api/v1/admin/*.
# By default, Clerk org roles org:admin and admin are allowed.
CLERK_ADMIN_USER_IDS=
CLERK_ADMIN_ORG_ROLES=org:admin,admin
CLERK_ADMIN_ORG_PERMISSIONS=

# ---------------------------------------------------------------------------
# ML prediction service
# ---------------------------------------------------------------------------
# Base URL for the FastAPI ML service. When unset, the backend falls back to
# precomputed scores from the database.
#
# Local development example when running the ML service on port 8000:
#   ML_API_BASE_URL=http://localhost:8000
#
# Docker network deployment example when backend and ML are both on zentra:
#   ML_API_BASE_URL=http://zentra-ml:8000
ML_API_BASE_URL=http://localhost:8000

# Timeout for ML service calls in milliseconds. Defaults to 5000 when unset or invalid.
ML_API_TIMEOUT_MS=5000
